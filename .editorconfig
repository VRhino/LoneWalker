root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# Dart
[*.dart]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
