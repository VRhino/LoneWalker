# ============================================
# LONEWALKER - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# DATABASE - PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lonewalker_dev
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SYNCHRONIZE=true
DB_LOGGING=true

# ============================================
# CACHE - Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# AUTHENTICATION - JWT
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800
JWT_ALGORITHM=HS256

# ============================================
# EXTERNAL SERVICES - Google Maps API
# ============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_STATIC_API_KEY=your_google_maps_static_api_key_here

# ============================================
# AUTHENTICATION - Firebase
# ============================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# ============================================
# STORAGE - AWS S3 / Google Cloud Storage
# ============================================
# For Google Cloud Storage (recommended for GCP)
GCS_BUCKET_NAME=lonewalker-dev-bucket
GCS_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Alternative: AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=lonewalker-dev
AWS_REGION=eu-west-1

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# MOBILE APP - Flutter Configuration
# ============================================
FLUTTER_ENVIRONMENT=development
API_BASE_URL=http://localhost:3000/api/v1
SOCKET_URL=http://localhost:3000
