# ============================================================
# Railway Production Environment Variables
# Set these in: Railway Dashboard → Service → Variables
# ============================================================

# --- Provided automatically by Railway plugins ---
# DATABASE_URL    ← Railway PostgreSQL plugin (set as reference variable)
# PORT            ← Railway injects this automatically

# --- Required: set manually in Railway dashboard ---

NODE_ENV=production

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Database — use DATABASE_URL from Railway PostgreSQL plugin (reference variable)
# If not using DATABASE_URL, set these individually:
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# DB_SYNCHRONIZE: true for initial testing (creates tables automatically).
# Switch to false once migrations are in place.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# CORS — set to the Railway public URL of this service + any other origins
# Example: https://lonewalker-backend.up.railway.app
CORS_ORIGIN=https://YOUR_RAILWAY_DOMAIN.up.railway.app
CORS_CREDENTIALS=true

# --- Redis (Phase 8.1 — required for caching) ---
# Railway: add Redis plugin and reference its REDIS_URL variable
# When REDIS_URL is set, individual REDIS_HOST/PORT/PASSWORD/DB are ignored
# REDIS_URL=redis://default:password@host.railway.internal:6379
#
# Local development (docker-compose redis):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# --- Optional ---
# GOOGLE_MAPS_API_KEY=
