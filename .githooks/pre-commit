#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$ROOT/frontend"
BACKEND_DIR="$ROOT/backend"

STAGED_DART=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.dart$' || true)
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep '^backend/.*\.ts$' || true)

# ── Backend lint ────────────────────────────────────────────────────────────
if [ -n "$STAGED_TS" ]; then
  echo "🔍 [pre-commit] Running backend lint..."

  echo "  → pnpm run lint"
  if ! (cd "$BACKEND_DIR" && pnpm run lint); then
    echo ""
    echo "❌ ESLint failed. Fix the issues above before committing."
    exit 1
  fi

  # Re-stage any files that --fix auto-corrected
  FIXED=$(git diff --name-only | grep '^backend/.*\.ts$' || true)
  if [ -n "$FIXED" ]; then
    echo "  ↺  Re-staging ESLint auto-fixes:"
    while IFS= read -r file; do
      echo "     $file"
      git add "$file"
    done <<< "$FIXED"
  fi

  echo "✅ Backend lint passed."
fi

# ── Frontend checks ─────────────────────────────────────────────────────────
if [ -n "$STAGED_DART" ]; then
  echo "🔍 [pre-commit] Running Flutter checks on frontend/..."

  echo "  → dart format ."
  (cd "$FRONTEND_DIR" && dart format .)

  # Re-stage dart files that dart format modified (originally staged)
  while IFS= read -r file; do
    if [ -f "$file" ]; then
      git add "$file"
    fi
  done <<< "$(git diff --cached --name-only --diff-filter=ACMR | grep '\.dart$' || true)"

  # Re-stage any additional files dart format touched
  FORMATTED=$(git diff --name-only | grep '\.dart$' || true)
  if [ -n "$FORMATTED" ]; then
    echo "  ↺  Re-staging dart format changes:"
    while IFS= read -r file; do
      echo "     $file"
      git add "$file"
    done <<< "$FORMATTED"
  fi

  echo "  → flutter analyze"
  if ! (cd "$FRONTEND_DIR" && flutter analyze --no-fatal-infos); then
    echo ""
    echo "❌ flutter analyze failed. Fix the issues above before committing."
    exit 1
  fi

  echo "✅ Flutter checks passed."
fi
