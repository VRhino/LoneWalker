#!/usr/bin/env bash
set -euo pipefail

FRONTEND_DIR="$(git rev-parse --show-toplevel)/frontend"

# Check if any .dart files are staged
STAGED_DART=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.dart$' || true)
if [ -z "$STAGED_DART" ]; then
  exit 0
fi

echo "🔍 [pre-commit] Running Flutter checks on frontend/..."

# --- dart format ---
echo "  → dart format ."
(cd "$FRONTEND_DIR" && dart format .)

# Re-stage any files that dart format modified (only previously-staged files)
while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done <<< "$(git diff --cached --name-only --diff-filter=ACMR | grep '\.dart$' || true)"

# Additionally re-stage files that dart format touched but weren't originally staged
FORMATTED=$(git diff --name-only | grep '\.dart$' || true)
if [ -n "$FORMATTED" ]; then
  echo "  ↺  Re-staging dart format changes:"
  while IFS= read -r file; do
    echo "     $file"
    git add "$file"
  done <<< "$FORMATTED"
fi

# --- flutter analyze ---
echo "  → flutter analyze"
if ! (cd "$FRONTEND_DIR" && flutter analyze --no-fatal-infos); then
  echo ""
  echo "❌ flutter analyze failed. Fix the issues above before committing."
  exit 1
fi

echo "✅ Flutter checks passed."
